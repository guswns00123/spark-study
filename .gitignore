# =============================================================
# Spark 학습 저장소 — .gitignore
# =============================================================

# -------------------------------------------------------------
# Spark 데이터 / 출력물
# named volume이지만 bind mount 흔적이 생길 경우를 대비
# -------------------------------------------------------------
data/
!data/.gitkeep
data_gen/output/
spark-events/

# -------------------------------------------------------------
# Spark 로그 / 로컬 메타스토어
# spark-submit 실행 시 자동 생성되는 Derby DB, 이벤트 로그
# -------------------------------------------------------------
*.log
derby.log
metastore_db/

# -------------------------------------------------------------
# Python 캐시
# -------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.eggs/
*.egg-info/
dist/
build/

# -------------------------------------------------------------
# Jupyter 체크포인트 (원본 .py 가 있으므로 체크포인트 불필요)
# -------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -------------------------------------------------------------
# Claude / 로컬 에이전트 설정
# .claude/agents/*.md 는 공유 대상이지만 settings.local.json은 개인 설정
# -------------------------------------------------------------
.claude/settings.local.json

# -------------------------------------------------------------
# 편집기 캐시
# -------------------------------------------------------------
.idea/
.vscode/
*.suo
*.user
.vs/

# -------------------------------------------------------------
# OS 노이즈
# -------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
$RECYCLE.BIN/

# -------------------------------------------------------------
# 환경 변수 / 시크릿
# -------------------------------------------------------------
.env
.env.local
*.pem
*.key
